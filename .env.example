# Copy to .env and fill in. Loaded by cmd/employee-factory via godotenv.

# --- LLM model/provider (OpenRouter default) ---
# LLM_BASE_URL defaults to https://openrouter.ai/api/v1 in code.
LLM_MODEL=google/gemini-2.0-flash-001
# Preferred local name for the OpenRouter API key (synced to cluster Secret key LLM_API_KEY).
# OPENROUTER_API_KEY=…
OPENROUTER_KEY=
# Per-employee overrides ({ALEX,TIM,ROSS,GARTH}_MODEL) win over LLM_MODEL and override the cluster ConfigMap.
# They must be valid for LLM_BASE_URL (e.g. OpenRouter slugs like google/gemini-2.0-flash-001 — not Chutes-only ids).

# --- Slack threads (#chat) — CEO-only threaded sessions ---
# Set both to enable thread routing (Socket Mode already receives thread replies; no extra webhooks).
# Aliases (either name works): SLACK_CEO_USER_ID / SLACK_CHANNEL_ID
CHAT_ALLOWED_USER_ID=
SLACK_CHAT_CHANNEL_ID=
SLACK_CEO_USER_ID=
SLACK_CHANNEL_ID=

# --- Company-channel runtime contract (first pass) ---
# Optional JSON array mapping Slack channels to company runtime metadata.
# Keep COMPANY_CHANNELS_ENFORCE=false while migrating; set true to ignore events
# from channels not declared in COMPANY_CHANNELS_JSON.
# Example:
# COMPANY_CHANNELS_JSON=[{"company_slug":"bimross","channel_id":"C0APJT7PYUU","display_name":"BimRoss","primary_owner":"grant","threads_enabled":true,"general_auto_reaction_enabled":false}]
COMPANY_CHANNELS_JSON=
COMPANY_CHANNELS_ENFORCE=false
# Availability/signoff router: deterministic cue classification + async-safe ack policy.
# Keep ROUTER_AVAILABILITY_ENABLED=false for no behavior change.
# Set ROUTER_LOG_ONLY=true to inspect router_decision logs without enforcement first.
ROUTER_AVAILABILITY_ENABLED=false
ROUTER_LOG_ONLY=false
# Runtime intelligence lessons: lightweight capture + guarded prompt injection.
# Start with LESSONS_ENABLED=true and LESSONS_LOG_ONLY=true to observe behavior safely.
LESSONS_ENABLED=false
LESSONS_LOG_ONLY=true
LESSONS_AUTO_APPLY=true
# Candidate confidence gate [0..1].
LESSONS_MIN_CONFIDENCE=0.8
# Max active lessons injected into prompts.
LESSONS_MAX_ACTIVE=3
# Active lesson TTL in seconds (default 7 days).
LESSONS_TTL_SEC=604800
# Event retention cap in Redis list.
LESSONS_MAX_EVENTS=200
# Prompt budget for runtime lessons prefix.
LESSONS_MAX_PROMPT_RUNES=600

# --- Slack presentation layer (text-first defaults) ---
# Keep human chat feel by default. Enable blocks only for bounded structured responses.
SLACK_PRESENTATION_ENABLE_BLOCKS=false
# Structured rendering mode: off | auto | force_for_structured
SLACK_PRESENTATION_JSON_MODE=off
# Max rows/items shown in block templates before falling back to text.
SLACK_PRESENTATION_MAX_BLOCK_ITEMS=8

# --- Joanne Gmail tooling (first vertical slice) ---
# Enable only for the Joanne runtime (EMPLOYEE_ID=joanne).
JOANNE_EMAIL_ENABLED=false
# OAuth desktop/web client credentials for Gmail API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Long-lived refresh token for Joanne's Google account (gmail.send scope).
GOOGLE_REFRESH_TOKEN=
# Mailbox address to use in the From header.
GOOGLE_SENDER_EMAIL=
# Optional display name in the From header (defaults to "Joanne" for EMPLOYEE_ID=joanne).
GOOGLE_SENDER_NAME=

# Optional: Redis caches human-root thread owner across pods (owner can still be inferred from thread history without it).
REDIS_URL=
THREAD_OWNER_TTL_SEC=2592000

# --- Ross ops tooling (read-only vertical via ops proxy) ---
# Enable only for EMPLOYEE_ID=ross.
ROSS_OPS_ENABLED=false
ROSS_OPS_LOG_ONLY=false
# In-cluster URL for read-only ops proxy service.
ROSS_OPS_PROXY_URL=http://employee-factory-ops-proxy.employee-factory.svc.cluster.local:8080
# Shared auth token for Ross -> ops proxy requests.
ROSS_OPS_PROXY_TOKEN=
# Default namespace used when Ross request omits namespace.
ROSS_OPS_DEFAULT_NAMESPACE=employee-factory
# Ops proxy allowlists and limits (consumed by cmd/ops-proxy).
OPS_PROXY_ALLOWED_NAMESPACES=employee-factory
OPS_PROXY_ALLOWED_REDIS_PREFIXES=thread_owner:,waitlist:,makeacompany:waitlist:
OPS_PROXY_WAITLIST_PREFIXES=waitlist:,makeacompany:waitlist:
OPS_PROXY_DEFAULT_STATUS_LIMIT=8
OPS_PROXY_MAX_STATUS_LIMIT=25
OPS_PROXY_DEFAULT_REDIS_LIMIT=10
OPS_PROXY_MAX_REDIS_LIMIT=50
OPS_PROXY_DEFAULT_WAITLIST_LIMIT=50
OPS_PROXY_MAX_WAITLIST_LIMIT=250
OPS_PROXY_DEFAULT_LOG_TAIL_LINES=200
OPS_PROXY_MAX_LOG_TAIL_LINES=500
OPS_PROXY_MAX_LOG_BYTES=20000
OPS_PROXY_REQUEST_TIMEOUT_SEC=30

# When true, main-channel LLM context includes compact snippets from threads on recent messages (extra Slack API calls).
LLM_CHANNEL_INCLUDE_THREADS=false
LLM_CHANNEL_THREAD_PARENT_SCAN=4
LLM_CHANNEL_THREAD_REPLIES_MAX=15
# Newest message gets highest context weight, with capped decay over older messages.
LLM_CONTEXT_WEIGHT_DECAY=0.5
LLM_CONTEXT_WEIGHT_WINDOW=3

# --- LLM resilience (same LLM_BASE_URL + API key; optional smaller fallback model) ---
# Higher max token budget reduces model-side truncation; succinctness is still prompt-governed.
LLM_MAX_TOKENS=900
# Extra attempts on transient errors (429/502/503, "No instances available").
LLM_MAX_RETRIES=2
# Base delay before first retry; doubles each retry (capped at 8s in code).
LLM_RETRY_BACKOFF_MS=400
# Hard timeout per completion call so one stalled provider request cannot block event handling.
LLM_REPLY_TIMEOUT_SEC=35
# Leave empty to run single-model mode.
LLM_FALLBACK_MODEL=
# Timeout budget (seconds) for one quick fallback attempt.
LLM_FALLBACK_TIMEOUT_SEC=8

# --- Multi-agent broadcast (<!everyone>) — same values on all squad pods ---
# MULTIAGENT_ORDER and per-bot Slack user ids are set in deploy/ConfigMap in production.
# Optional: extra entropy for turn-order shuffle (must match across pods if set).
MULTIAGENT_SHUFFLE_SECRET=
# Plain-message #general auto-reaction (Grant only): choose one deterministic random winner when no @mentions.
# Requires CHAT_ALLOWED_USER_ID, SLACK_GENERAL_CHANNEL_ID, and multi-agent order/user IDs configured.
SLACK_GENERAL_CHANNEL_ID=
MULTIAGENT_GENERAL_AUTO_REACTION_ENABLED=false
# Full passes over the shuffled squad per broadcast (1 = each agent once).
MULTIAGENT_BROADCAST_ROUNDS=1
# Multi-agent slot waiting: do not block downstream agents forever if a predecessor stalls.
MULTIAGENT_SLOT_SOFT_TIMEOUT_SEC=12
MULTIAGENT_ALLOW_DEGRADED_START=true
# Per-reply chance [0..1] to include exactly one other-agent @mention during broadcast runs.
# When unset, falls back to MULTIAGENT_HANDOFF_PROBABILITY (default 0.5).
MULTIAGENT_BROADCAST_HANDOFF_PROBABILITY=0.35
# Per-reply handoff chance is sampled within this range on direct, thread, and multi-agent replies.
MULTIAGENT_HANDOFF_MIN_PROBABILITY=0.25
MULTIAGENT_HANDOFF_MAX_PROBABILITY=0.75
# Global chatter cap for cross-agent handoff mentions. Default runtime cap is 0.25.
# Set to 1.0 only if you intentionally want high banter.
MULTIAGENT_CHATTER_CAP=0.25
# Deterministic branch mode for <!everyone>: with probability below, switch to branch handoff probability.
MULTIAGENT_BROADCAST_BRANCHING_ENABLED=true
MULTIAGENT_BROADCAST_BRANCHING_PROBABILITY=0.5
# Per-reply handoff probability used only when branch mode is selected.
MULTIAGENT_BROADCAST_BRANCHING_HANDOFF_PROBABILITY=0.6
