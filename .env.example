# Copy to .env (never commit .env). Canonical keys for Kubernetes:
# LLM_API_KEY, SLACK_BOT_TOKEN, SLACK_APP_TOKEN, LLM_BASE_URL, LLM_MODEL, EMPLOYEE_ID
#
# Secrets direction: you edit .env locally, then ./scripts/update-runtime-secrets.sh pushes into the
# cluster Secret (employee-factory-<id>-runtime). It does not pull from the cluster or rewrite .env.
# Per-employee model override: {EMPLOYEE_ID}_MODEL (e.g. BOB_MODEL) or ALEX_MODEL when id is alex.
# --- Local Alex-friendly names (supported without EMPLOYEE_ID) ---
ALEX_CHUTES_KEY=
ALEX_MODEL=
ALEX_SLACK_BOT_TOKEN=
ALEX_SLACK_APP_TOKEN=

# --- Tim (use with EMPLOYEE_ID=tim when applying the tim runtime secret) ---
TIM_CHUTES_KEY=
TIM_MODEL=
TIM_SLACK_BOT_TOKEN=
TIM_SLACK_APP_TOKEN=

# --- Garth (use with EMPLOYEE_ID=garth when applying the garth runtime secret) ---
GARTH_CHUTES_KEY=
GARTH_MODEL=
GARTH_SLACK_BOT_TOKEN=
GARTH_SLACK_APP_TOKEN=

# --- Or canonical names ---
# LLM_API_KEY=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

EMPLOYEE_ID=alex
LLM_BASE_URL=https://llm.chutes.ai/v1
LLM_MODEL=unsloth/Llama-3.2-1B-Instruct
# Persona size / completion budget (defaults match internal/config).
# Persona + Slack rules rune ceiling (default 48000). Alex Slack bundle is trimmed via personas/alex-slack.exclude; raise only if you add large rules back into the bundle.
# LLM_SYSTEM_MAX_RUNES=48000
# Reply length ceiling (default 512). Brevity is prompt-driven; raise only if you need longer replies.
# LLM_MAX_TOKENS=512
# LLM_TEMPERATURE=0.55
# Optional per-employee override when EMPLOYEE_ID is set (e.g. ross → ROSS_LLM_TEMPERATURE). Slight spread reduces duplicate squad phrasing.
# ROSS_LLM_TEMPERATURE=0.52
# TIM_LLM_TEMPERATURE=0.58
# ALEX_LLM_TEMPERATURE=0.56
# GARTH_LLM_TEMPERATURE=0.60
# Optional nucleus sampling (omit to use provider default).
# LLM_TOP_P=0.95
# Slack context (no extra LLM inference): earlier messages on the channel timeline via
# conversations.history before the current message (BimRoss: one open channel, no threads/DMs).
# Env names remain LLM_THREAD_* for backward compatibility with existing ConfigMaps.
# LLM_THREAD_MAX_MESSAGES=25
# LLM_THREAD_MAX_RUNES=16000
# Alex only: deterministic keyword hints prepended to user text (set 0 to disable).
# LLM_ALEX_HINTS=1

# Outbound Slack rate limit (per bot): max posts in a rolling window. Stops runaway multi-agent
# @mention loops (further replies wait for the next human message). Defaults: 10 posts / 60s. 0 = off.
# SLACK_OUTBOUND_WINDOW_SEC=60
# SLACK_OUTBOUND_MAX_PER_WINDOW=10

# Multi-agent sequencing (optional): when two or more squad bots are @mentioned in a channel,
# replies are ordered on the channel timeline (no thread). One full ordered pass per trigger unless noted below.
# Slack <!everyone> / <!channel> (no bot @mention): each squad process runs the same session; round count is
# sampled so mean total squad posts ≈ MULTIAGENT_BROADCAST_TARGET_MESSAGES (default 10), with variance.
# Per-reply @mention nudge probability: MULTIAGENT_HANDOFF_PROBABILITY (default 0.5); for broadcast-only override
# use MULTIAGENT_BROADCAST_HANDOFF_PROBABILITY (else same as HANDOFF).
# MULTIAGENT_BROADCAST_TARGET_MESSAGES=10
# MULTIAGENT_BROADCAST_MAX_ROUNDS=6
# MULTIAGENT_HANDOFF_PROBABILITY=0.5
# MULTIAGENT_BROADCAST_HANDOFF_PROBABILITY=0.5
# Set MULTIAGENT_ORDER plus either MULTIAGENT_BOT_USER_IDS or each *_SLACK_BOT_ID.
# Canonical BimRoss #chat squad (keep in sync with rancher-admin ConfigMap + docs/slack-squad-ids.md):
# ROSS_SLACK_BOT_ID=U0APX108QE7
# TIM_SLACK_BOT_ID=U0AQ10R2H8E
# ALEX_SLACK_BOT_ID=U0APSMH05B5
# GARTH_SLACK_BOT_ID=U0GARTH00000
# MULTIAGENT_BOT_USER_IDS=ross:U0APX108QE7,tim:U0AQ10R2H8E,alex:U0APSMH05B5,garth:U0GARTH00000
# MULTIAGENT_ORDER=ross,tim,alex,garth
# MULTIAGENT_ENABLED=1
# MULTIAGENT_POLL_INTERVAL_MS=800
# MULTIAGENT_WAIT_TIMEOUT_SEC=300

HTTP_ADDR=:8080
PERSONA_PATH=./persona.local.md
PERSONA_RELOAD_MS=60000
