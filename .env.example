# Copy to .env and fill in. Loaded by cmd/employee-factory via godotenv.

# --- Slack threads (#chat) — CEO-only threaded sessions ---
# Set both to enable thread routing (Socket Mode already receives thread replies; no extra webhooks).
# Aliases (either name works): SLACK_CEO_USER_ID / SLACK_CHANNEL_ID
CHAT_ALLOWED_USER_ID=
SLACK_CHAT_CHANNEL_ID=
SLACK_CEO_USER_ID=
SLACK_CHANNEL_ID=

# Optional: Redis caches human-root thread owner across pods (owner can still be inferred from thread history without it).
REDIS_URL=
THREAD_OWNER_TTL_SEC=2592000

# When true, main-channel LLM context includes compact snippets from threads on recent messages (extra Slack API calls).
LLM_CHANNEL_INCLUDE_THREADS=false
LLM_CHANNEL_THREAD_PARENT_SCAN=4
LLM_CHANNEL_THREAD_REPLIES_MAX=15

# --- Chutes / LLM resilience (same LLM_BASE_URL + API key; optional smaller fallback model) ---
# Extra attempts on transient errors (429/502/503, "No instances available").
LLM_MAX_RETRIES=2
# Base delay before first retry; doubles each retry (capped at 8s in code).
LLM_RETRY_BACKOFF_MS=400
# If set and different from LLM_MODEL, one completion attempt uses this model after primary exhausts retries (e.g. small Llama when large model has no instances).
LLM_FALLBACK_MODEL=unsloth/Llama-3.2-1B-Instruct

# --- Multi-agent broadcast (<!everyone> / <!channel>) — same values on all squad pods ---
# MULTIAGENT_ORDER and per-bot Slack user ids are set in deploy/ConfigMap in production.
# Optional: extra entropy for turn-order shuffle (must match across pods if set).
MULTIAGENT_SHUFFLE_SECRET=
# Full passes over the shuffled squad per broadcast (1 = each agent once).
MULTIAGENT_BROADCAST_ROUNDS=1
