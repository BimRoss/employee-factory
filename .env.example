# Copy to .env (never commit .env). Canonical keys for Kubernetes:
# LLM_API_KEY, SLACK_BOT_TOKEN, SLACK_APP_TOKEN, LLM_BASE_URL, LLM_MODEL, EMPLOYEE_ID
# Per-employee model override: {EMPLOYEE_ID}_MODEL (e.g. BOB_MODEL) or ALEX_MODEL when id is alex.
# --- Local Alex-friendly names (supported without EMPLOYEE_ID) ---
ALEX_CHUTES_KEY=
ALEX_MODEL=
ALEX_SLACK_BOT_TOKEN=
ALEX_SLACK_APP_TOKEN=

# --- Tim (use with EMPLOYEE_ID=tim when applying the tim runtime secret) ---
TIM_CHUTES_KEY=
TIM_MODEL=
TIM_SLACK_BOT_TOKEN=
TIM_SLACK_APP_TOKEN=

# --- Or canonical names ---
# LLM_API_KEY=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

EMPLOYEE_ID=alex
LLM_BASE_URL=https://llm.chutes.ai/v1
LLM_MODEL=unsloth/Llama-3.2-1B-Instruct
# Persona size / completion budget (defaults match internal/config).
# LLM_SYSTEM_MAX_RUNES=48000
# Reply length ceiling (default 1024). Lower only for cost control; brevity is prompt-driven.
# LLM_MAX_TOKENS=1024
# LLM_TEMPERATURE=0.55
# Optional nucleus sampling (omit to use provider default).
# LLM_TOP_P=0.95
# Slack context (no extra LLM inference): earlier messages on the channel timeline via
# conversations.history before the current message (BimRoss: one open channel, no threads/DMs).
# Env names remain LLM_THREAD_* for backward compatibility with existing ConfigMaps.
# LLM_THREAD_MAX_MESSAGES=25
# LLM_THREAD_MAX_RUNES=16000
# Alex only: deterministic keyword hints prepended to user text (set 0 to disable).
# LLM_ALEX_HINTS=1

# Outbound Slack rate limit (per bot): max posts in a rolling window. Stops runaway multi-agent
# @mention loops (further replies wait for the next human message). Defaults: 10 posts / 60s. 0 = off.
# SLACK_OUTBOUND_WINDOW_SEC=60
# SLACK_OUTBOUND_MAX_PER_WINDOW=10

# Multi-agent sequencing (optional): when two or more squad bots are @mentioned in a channel,
# replies are ordered on the channel timeline (no thread). Two full rounds if the message has Slack <!everyone…> or the word
# “everyone” as a whole word. <!channel…> is one round. @everyone / @channel with no bot @mention
# is handled only by the first name in MULTIAGENT_ORDER (message.channels coordinator).
# Set MULTIAGENT_ORDER plus either MULTIAGENT_BOT_USER_IDS or
# each bot’s Slack user id (Auth Test / app “Bot User” id), e.g. TIM_SLACK_BOT_ID=U….
# ROSS_SLACK_BOT_ID=
# TIM_SLACK_BOT_ID=
# ALEX_SLACK_BOT_ID=
# MULTIAGENT_BOT_USER_IDS=ross:U0123ABC,tim:U0456DEF,alex:U0789GHI
# MULTIAGENT_ORDER=ross,tim,alex
# MULTIAGENT_ENABLED=1
# MULTIAGENT_POLL_INTERVAL_MS=800
# MULTIAGENT_WAIT_TIMEOUT_SEC=300

HTTP_ADDR=:8080
PERSONA_PATH=./persona.local.md
PERSONA_RELOAD_MS=60000
