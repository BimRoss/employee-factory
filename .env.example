# Copy to .env (never commit .env). Canonical keys for Kubernetes:
# LLM_API_KEY, SLACK_BOT_TOKEN, SLACK_APP_TOKEN, LLM_BASE_URL, LLM_MODEL, EMPLOYEE_ID
# Per-employee model override: {EMPLOYEE_ID}_MODEL (e.g. BOB_MODEL) or ALEX_MODEL when id is alex.
# Persona CronJob clone (scripts/update-runtime-secrets.sh): CURSOR_RULES_GITHUB_TOKEN (read bimross/cursor-rules)

# --- Local Alex-friendly names (supported without EMPLOYEE_ID) ---
ALEX_CHUTES_KEY=
ALEX_MODEL=
ALEX_SLACK_BOT_TOKEN=
ALEX_SLACK_APP_TOKEN=

# PAT for hourly persona sync (kubectl secret key remains GITHUB_TOKEN in-cluster)
CURSOR_RULES_GITHUB_TOKEN=

# --- Or canonical names ---
# LLM_API_KEY=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

EMPLOYEE_ID=alex
LLM_BASE_URL=https://llm.chutes.ai/v1
LLM_MODEL=unsloth/Llama-3.2-1B-Instruct
# Persona size / completion budget (defaults match internal/config): avoid 16k context overflow.
# LLM_SYSTEM_MAX_RUNES=48000
# Reply length cap (default 256 ≈ short Slack message). Raise for long-form only.
# LLM_MAX_TOKENS=256

HTTP_ADDR=:8080
PERSONA_PATH=./persona.local.md
PERSONA_RELOAD_MS=60000
